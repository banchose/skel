    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "пА£",
            "unlocked": "пВЬ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "пЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) вЄ®{songPosition}|{queueLength}вЄ© {volume}% пАБ",
        "format-disconnected": "Disconnected пАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped пАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "artist-len": 5,
        "album-len": 5,
        "album-artist-len": 5,
        "title-len": 5,
        "consume-icons": {
            "on": "пГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">пБі</span> ",
            "on": "пБі "
        },
        "repeat-icons": {
            "on": "пАЮ "
        },
        "single-icons": {
            "on": "пАЮ1 "
        },
        "state-icons": {
            "paused": "пБМ",
            "playing": "пБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click": "mpc toggle",
        "on-click-middle": "mpc pause;mpc seek +00:00:15;mpc play",
        "on-click-right": "mpc pause;mpc seek -00:00:15;mpc play"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пБЃ",
            "deactivated": "пБ∞"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "format": "{:%H %M %a %m %d %y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
//     "cpu": {
//         "format": "{avg_frequency}GHz пЛЫ",
//         "tooltip": false
//     },
    "cpu": {
        "interval": 1,
        "format": "{icon0}{icon1}{icon2}{icon2} {usage:>2}% пБВ",
        "format-icons": ["вЦБ", "вЦВ", "вЦГ", "вЦД", "вЦЕ", "вЦЖ", "вЦЗ", "вЦИ"]
    },
    "memory": {
        "format": "{}% пГЙ"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}¬∞C {icon}",
        "format": "{temperatureC}¬∞C {icon}",
        "format-icons": ["пЭЂ", "пЛЙ", "пЭ©"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% пЧІ",
        "format-plugged": "{capacity}% пЗ¶",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface" : "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) пЗЂ",
        "format-ethernet": "{ipaddr}/{cidr} пЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} пЮЦ",
        "format-linked": "{ifname} (No IP) пЮЦ",
        "format-disconnected": "Disconnected вЪ†",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
        "format-bluetooth-muted": "пЪ© {icon}пКФ {format_source}",
        "format-muted": "пЪ© {format_source}",
        "format-source": "{volume}% пД∞",
        "format-source-muted": "пД±",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "пА®"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "custom/firefox-Super-Default": {
        "format": "пЙ©",
        "on-click": "firefox -P Super-Default",
        "on-click-right": "firefox --ProfileManager"
    },
    "custom/firefox-youtube": {
        "format": "пЙ©",
        "on-click": "firefox -P Youtube",
        "on-click-right": "firefox --ProfileManager"
    },
    "custom/firefox-TV": {
        "format": "пЙ©",
        "on-click": "firefox -P TV",
        "on-click-right": "firefox --ProfileManager"
    },
    "custom/firefox-Other": {
        "format": "пЙ©",
        "on-click": "firefox -P LastPass",
        "on-click-right": "firefox --ProfileManager"
    },
    "custom/firefox-PIA": {
        "format": "пЙ©",
        "on-click": "firefox -P PIA-Attempt",
        "on-click-right": "firefox --ProfileManager"
    },
    "custom/librewolf-default": {
        "format": "пЙ©",
        "on-click": "/usr/bin/librewolf -P Super-Default",
        "on-click-right": "/usr/bin/librewolf --ProfileManager"
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1"
    },
    "custom/pinger": {
        "exec" : "~/.config/waybar/pinger.sh",
        "format":"{icon} {0}",
        "interval": 10,
        "return-type": "json",
        "min-length": 4,
        "format-icons": {
            "default": "пЯА",
            "low":"пГђ"
        }
    },
   "custom/1min": {
        "exec" : "cut -f1 -d' ' /proc/loadavg",
        "format":"{icon} {0}",
        "interval": 10,
        "min-length": 4,
        "format-icons": {
            "default": "пЛЫ",
            "low":"пГђ"
        }
    },
    "custom/5min": {
        "exec" : "cut -f2 -d' ' /proc/loadavg",
        "format":"{icon} {0}",
        "interval": 10,
        "min-length": 4,
        "format-icons": {
            "default": "пЛЫ",
            "low":"пГђ"
        }
    },
    "custom/15min": {
        "exec" : "cut -f3 -d' ' /proc/loadavg",
        "format":"{icon} {0}",
        "interval": 10,
        "min-length": 4,
        "format-icons": {
            "default": "пЛЫ",
            "low":"пГђ"
        }
    },
    "custom/Ping_firewall": {
      "exec" : "/home/una/.config/waybar/scripts/ping_firewall.sh",
      "format":"{icon} {0}",
      "return-type": "json",
      "interval": 10,
      "min-length": 4,
      "format-icons": {
          "default": "пЯА",
          "low":"пГђ"
      }
    },
    "custom/Ping_fios": {
      "exec" : "/home/una/.config/waybar/scripts/ping_fios.sh",
      "format":"{icon} {0}",
      "return-type": "json",
      "interval": 10,
      "min-length": 4,
      "format-icons": {
          "default": "пЯА",
          "low":"пГђ"
      }
    },
    "custom/Ping_GW": {
      "exec" : "/home/una/.config/waybar/scripts/ping_gw.sh",
      "format":"{icon} {0}",
      "return-type": "json",
      "interval": 10,
      "min-length": 4,
      "format-icons": {
          "default": "пЯА",
          "low":"пГђ"
      }
    },
    "custom/clearmako": {
        "format": "рЯФК",
        "on-click": "makoctl dismiss --all"
    },
    "custom/media": {
        "format": "{icon}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "пЖЉ",
            "default": "рЯОЬ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/weather": {
        "exec": "~/.config/waybar/scripts/OPENWEATHER.sh",
        "return-type": "json",
        "interval": 700,
        "tooltip": true
    },
    "custom/oil": {
    "exec": "~/.config/waybar/scripts/market_indicator.sh CL=F рЯЫҐпЄП 'WTI Crude' oil '' dollar",
    "return-type": "json",
    "interval": 300,
    "tooltip": true,
    "min-length": 16
    },
    "custom/gold": {
        "exec": "~/.config/waybar/scripts/market_indicator.sh GC=F рЯ™Щ Gold gold '' dollar",
        "return-type": "json",
        "interval": 300,
        "tooltip": true,
        "min-length": 16
    },
    "custom/vix": {
        "exec": "~/.config/waybar/scripts/market_indicator.sh ^VIX рЯШ∞ VIX vix invert index",
        "return-type": "json",
        "interval": 300,
        "tooltip": true,
        "min-length": 14
    },
    "custom/tnx": {
        "exec": "~/.config/waybar/scripts/market_indicator.sh ^TNX рЯУИ '10Y Yield' tnx '' pct",
        "return-type": "json",
        "interval": 300,
        "tooltip": true,
        "min-length": 14
    }
}
