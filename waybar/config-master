    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces", "custom/librewolf-default", "custom/firefox-Super-Default", "custom/firefox-youtube", "custom/firefox-TV","custom/firefox-Other", "custom/librewolf-default", "custom/pinger", "custom/1min","custom/5min","custom/15min", "cpu", "custom/weather", "custom/oil"],
    "modules-center": ["clock"],
    "modules-right": ["custom/gold","custom/vix","custom/tnx","custom/Ping_GW","custom/Ping_fios", "custom/Ping_firewall", "idle_inhibitor", "custom/clearmako", "pulseaudio", "cpu", "memory", "temperature", "tray"],
